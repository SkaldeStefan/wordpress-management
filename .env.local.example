# Serverweite Standardwerte für install.sh
# Kopiere diese Datei nach .env.local und passe sie an.
# .env.local wird nie ins Repository eingecheckt.

# Name des externen Traefik-Netzwerks (Standard: traefik-proxy)
# TRAEFIK_NETWORK_NAME=traefik-proxy

# Kommagetrennte Traefik-Middlewares, z. B. für Authentifizierung
# TRAEFIK_MIDDLEWARES=authentik@file

# Stunde, zu der das automatische Backup läuft (0–23, Standard: 2)
# BACKUP_RUN_HOUR=3
